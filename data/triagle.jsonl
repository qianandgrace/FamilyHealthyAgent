{"symptom":"发烧","population":"儿童","triage_rules":[{"condition":"体温 < 38.5℃ 且精神好、能喝水、尿量正常","level":"low","action":"home"},{"condition":"体温 ≥ 38.5℃ 持续 > 48小时 或 反复高热退了又烧","level":"medium","action":"clinic"},{"condition":"<3个月婴儿发热≥38℃ 或 抽搐/意识不清/呼吸困难/紫癜样皮疹/明显脱水","level":"critical","action":"emergency"}]}
{"symptom":"发烧","population":"成人","triage_rules":[{"condition":"体温 < 38.5℃ 且精神尚可、无明显基础病、可进食饮水","level":"low","action":"home"},{"condition":"体温 ≥ 39℃ 或 发热持续 > 72小时 或 伴明显咳脓痰/尿痛/局部疼痛","level":"medium","action":"clinic"},{"condition":"意识改变/呼吸困难/胸痛/皮肤出血点或紫癜/严重头痛颈强直/免疫低下发热","level":"critical","action":"emergency"}]}
{"symptom":"咳嗽","population":"成人","triage_rules":[{"condition":"轻中度咳嗽，无呼吸困难，无高热，能正常活动","level":"low","action":"home"},{"condition":"咳嗽 > 3周 或 咳黄绿痰伴发热 或 既往慢阻肺/哮喘症状加重","level":"medium","action":"clinic"},{"condition":"呼吸困难/口唇发紫/无法完整说话/咳血/胸痛明显","level":"critical","action":"emergency"}]}
{"symptom":"咳嗽","population":"儿童","triage_rules":[{"condition":"轻度咳嗽，精神好，进食睡眠基本正常","level":"low","action":"home"},{"condition":"持续咳嗽影响睡眠或进食，或发热>48小时，或有喘鸣史","level":"medium","action":"clinic"},{"condition":"胸凹/鼻翼扇动/呻吟 或 呼吸急促明显 或 口唇发紫 或 疑误吸异物突发呛咳","level":"critical","action":"emergency"}]}
{"symptom":"喉咙痛","population":"成人","triage_rules":[{"condition":"轻度咽痛，无高热，能吞咽饮水","level":"low","action":"home"},{"condition":"高热或咽痛>3天 或 扁桃体明显肿大伴脓点 或 反复发作","level":"medium","action":"clinic"},{"condition":"吞咽困难明显/流口水/张口困难 或 呼吸困难/声音嘶哑快速加重","level":"critical","action":"emergency"}]}
{"symptom":"鼻塞流涕","population":"all","triage_rules":[{"condition":"轻度鼻塞流涕，无高热，无呼吸困难","level":"low","action":"home"},{"condition":"症状>10天不缓解 或 面颊/额头疼痛加重 或 脓涕明显","level":"medium","action":"clinic"},{"condition":"高热伴剧烈头痛/意识改变 或 眼眶周围红肿疼痛/视力变化","level":"critical","action":"emergency"}]}
{"symptom":"呼吸困难/气促","population":"all","triage_rules":[{"condition":"仅轻微气促，活动后出现，休息可缓解，无胸痛无发紫","level":"medium","action":"clinic"},{"condition":"静息也气促或夜间憋醒，或伴咳喘加重","level":"high","action":"emergency"},{"condition":"口唇/指甲发紫、无法完整说话、呼吸暂停感、意识不清","level":"critical","action":"emergency"}]}
{"symptom":"哮喘发作/喘鸣","population":"all","triage_rules":[{"condition":"轻度喘鸣，吸入支气管扩张剂后明显缓解","level":"medium","action":"clinic"},{"condition":"反复需要吸入药仍不缓解，或夜间频繁发作","level":"high","action":"emergency"},{"condition":"无法完整说话/胸凹明显/发紫/意识改变","level":"critical","action":"emergency"}]}
{"symptom":"胸痛","population":"成人","triage_rules":[{"condition":"与体位/按压相关的局部刺痛，无气促无出汗，持续时间短","level":"medium","action":"clinic"},{"condition":"运动时或情绪激动时胸闷胸痛，或反复发作","level":"high","action":"emergency"},{"condition":"压榨样胸痛>10分钟 或 放射至左臂/下颌 或 伴大汗/恶心/呼吸困难/晕厥","level":"critical","action":"emergency"}]}
{"symptom":"心悸","population":"成人","triage_rules":[{"condition":"短暂心悸，诱因明确（咖啡/熬夜/紧张），无胸痛晕厥","level":"medium","action":"clinic"},{"condition":"心悸反复、伴气短乏力或既往心脏病","level":"high","action":"emergency"},{"condition":"心悸伴胸痛/晕厥/意识模糊/明显呼吸困难","level":"critical","action":"emergency"}]}
{"symptom":"头痛","population":"成人","triage_rules":[{"condition":"既往类似头痛，强度轻中，休息/止痛药可缓解，无神经症状","level":"medium","action":"clinic"},{"condition":"新出现持续头痛>72小时 或 伴发热","level":"high","action":"emergency"},{"condition":"雷击样突发最剧烈头痛 或 伴意识改变/颈强直/抽搐/单侧无力/视力突然下降","level":"critical","action":"emergency"}]}
{"symptom":"眩晕/头晕","population":"成人","triage_rules":[{"condition":"体位改变相关短暂头晕，休息可缓解，无神经症状","level":"medium","action":"clinic"},{"condition":"持续眩晕伴恶心呕吐，影响行走","level":"high","action":"emergency"},{"condition":"眩晕伴走路不稳明显/说话不清/单侧无力麻木/复视","level":"critical","action":"emergency"}]}
{"symptom":"昏厥/晕倒","population":"all","triage_rules":[{"condition":"明确诱因（久站/疼痛/情绪）且很快恢复，无胸痛气促","level":"high","action":"emergency"},{"condition":"反复发生或伴心悸","level":"high","action":"emergency"},{"condition":"伴胸痛/呼吸困难/出血迹象/意识持续异常","level":"critical","action":"emergency"}]}
{"symptom":"抽搐","population":"all","triage_rules":[{"condition":"已确诊癫痫且发作<5分钟，发作后完全清醒且无外伤","level":"high","action":"emergency"},{"condition":"发作后持续嗜睡/发热/头部外伤史","level":"critical","action":"emergency"},{"condition":"首次抽搐 或 持续>5分钟 或 反复抽搐未恢复","level":"critical","action":"emergency"}]}
{"symptom":"恶心呕吐","population":"成人","triage_rules":[{"condition":"轻中度呕吐<24小时，能少量饮水，无剧烈腹痛","level":"low","action":"home"},{"condition":"持续呕吐>24小时 或 无法进水 或 伴发热/中重度腹痛","level":"medium","action":"clinic"},{"condition":"呕血/咖啡色呕吐物 或 意识改变/严重脱水/剧烈腹痛板状腹","level":"critical","action":"emergency"}]}
{"symptom":"恶心呕吐","population":"儿童","triage_rules":[{"condition":"呕吐次数少，能喝水，精神好，尿量尚可","level":"low","action":"home"},{"condition":"呕吐频繁>8-12小时 或 伴腹泻发热 或 精神变差","level":"medium","action":"clinic"},{"condition":"明显脱水（尿少/无泪/嗜睡）或 呕吐伴剧烈头痛/颈强直/血便","level":"critical","action":"emergency"}]}
{"symptom":"腹痛","population":"成人","triage_rules":[{"condition":"轻中度腹痛，进食后/排便后缓解，无发热无呕血黑便","level":"medium","action":"clinic"},{"condition":"持续加重的腹痛 或 右下腹痛伴恶心发热","level":"high","action":"emergency"},{"condition":"剧烈腹痛伴反跳痛/板状腹 或 伴晕厥/血便黑便/呕血","level":"critical","action":"emergency"}]}
{"symptom":"腹痛","population":"儿童","triage_rules":[{"condition":"轻度腹痛，能玩能吃，无持续呕吐","level":"medium","action":"clinic"},{"condition":"腹痛反复发作影响活动/睡眠，或伴发热呕吐","level":"high","action":"emergency"},{"condition":"持续剧痛、腹部僵硬、血便、精神差或无法唤醒","level":"critical","action":"emergency"}]}
{"symptom":"腹泻","population":"成人","triage_rules":[{"condition":"腹泻次数不多，无血便，无高热，能补液","level":"low","action":"home"},{"condition":"腹泻>3天 或 发热明显 或 频繁水样便影响补液","level":"medium","action":"clinic"},{"condition":"血便/黑便 或 低血压晕厥/明显脱水/持续呕吐无法进水","level":"critical","action":"emergency"}]}
{"symptom":"腹泻","population":"儿童","triage_rules":[{"condition":"轻度腹泻，精神好，能喝口服补液，尿量正常","level":"low","action":"home"},{"condition":"腹泻频繁>24-48小时 或 发热 或 呕吐较多","level":"medium","action":"clinic"},{"condition":"明显脱水（尿少/嗜睡/眼窝凹）或 血便 或 持续呕吐无法补液","level":"critical","action":"emergency"}]}
{"symptom":"便血","population":"adult","triage_rules":[{"condition":"少量鲜红便血，疑痔疮且无头晕乏力","level":"medium","action":"clinic"},{"condition":"反复便血或伴腹痛/发热","level":"high","action":"emergency"},{"condition":"大量便血 或 便血伴头晕心慌乏力/晕厥 或 黑便柏油样便","level":"critical","action":"emergency"}]}
{"symptom":"黑便","population":"adult","triage_rules":[{"condition":"可疑饮食/药物（铁剂/铋剂）导致且无不适","level":"medium","action":"clinic"},{"condition":"黑便伴上腹不适或乏力","level":"high","action":"emergency"},{"condition":"黑便伴呕血/晕厥/心慌大汗/血压低","level":"critical","action":"emergency"}]}
{"symptom":"呕血","population":"adult","triage_rules":[{"condition":"少量血丝且明确咽喉出血来源可能","level":"high","action":"emergency"},{"condition":"反复呕血或咖啡色呕吐物","level":"critical","action":"emergency"},{"condition":"呕血伴黑便/头晕晕厥/心跳快血压低","level":"critical","action":"emergency"}]}
{"symptom":"尿痛/尿频","population":"adult","triage_rules":[{"condition":"轻度尿痛尿频，无发热无腰痛","level":"medium","action":"clinic"},{"condition":"尿痛伴发热或腰痛","level":"high","action":"emergency"},{"condition":"高热寒战、恶心呕吐、明显腰背痛或疑败血症表现（意识差/低血压）","level":"critical","action":"emergency"}]}
{"symptom":"血尿","population":"all","triage_rules":[{"condition":"少量血尿且无不适","level":"high","action":"emergency"},{"condition":"血尿伴腰痛（疑结石）或伴发热（疑感染）","level":"high","action":"emergency"},{"condition":"血尿伴尿量减少/血块排不出/头晕低血压","level":"critical","action":"emergency"}]}
{"symptom":"排尿困难/尿潴留","population":"adult","triage_rules":[{"condition":"排尿变细/费力但仍能排出","level":"medium","action":"clinic"},{"condition":"排不出尿伴下腹胀痛","level":"high","action":"emergency"},{"condition":"尿潴留伴发热寒战/意识差/严重疼痛或既往神经系统疾病","level":"critical","action":"emergency"}]}
{"symptom":"下背痛/腰痛","population":"adult","triage_rules":[{"condition":"劳损相关腰痛，无发热无神经症状","level":"medium","action":"clinic"},{"condition":"腰痛伴放射到腿、麻木无力或大小便功能改变","level":"high","action":"emergency"},{"condition":"腰痛伴发热寒战（疑肾盂肾炎）或外伤后剧痛不能站立","level":"critical","action":"emergency"}]}
{"symptom":"颈部疼痛/僵硬","population":"all","triage_rules":[{"condition":"姿势劳损相关，可活动，无发热","level":"medium","action":"clinic"},{"condition":"疼痛持续加重或伴发热头痛","level":"high","action":"emergency"},{"condition":"发热+颈强直/畏光/意识改变或皮疹出血点","level":"critical","action":"emergency"}]}
{"symptom":"皮疹","population":"all","triage_rules":[{"condition":"轻度皮疹不痒或轻痒，无发热无呼吸困难","level":"medium","action":"clinic"},{"condition":"皮疹伴发热或明显瘙痒肿胀","level":"high","action":"emergency"},{"condition":"皮疹伴紫癜/出血点 或 口唇舌喉肿胀/喘憋 或 眼口黏膜糜烂疑重症药疹","level":"critical","action":"emergency"}]}
{"symptom":"荨麻疹/过敏","population":"all","triage_rules":[{"condition":"局部风团瘙痒，无喘憋，无面唇肿","level":"medium","action":"clinic"},{"condition":"全身风团反复、伴轻度面部肿胀","level":"high","action":"emergency"},{"condition":"喉头水肿/声音嘶哑快速加重/呼吸困难/头晕血压低","level":"critical","action":"emergency"}]}
{"symptom":"眼痛/眼红","population":"all","triage_rules":[{"condition":"轻度异物感或结膜充血，无视力下降","level":"medium","action":"clinic"},{"condition":"眼痛明显或畏光流泪、分泌物多","level":"high","action":"emergency"},{"condition":"视力突然下降/剧烈眼痛伴头痛恶心（疑急性青光眼）或 化学品入眼/穿通伤","level":"critical","action":"emergency"}]}
{"symptom":"视力下降/视物模糊","population":"all","triage_rules":[{"condition":"缓慢加重、无疼痛（如干眼/屈光问题可能）","level":"medium","action":"clinic"},{"condition":"突然视物模糊或视野缺损","level":"high","action":"emergency"},{"condition":"突然失明/复视伴神经症状（口齿不清、单侧无力）","level":"critical","action":"emergency"}]}
{"symptom":"耳痛","population":"all","triage_rules":[{"condition":"轻中度耳痛，无高热，无耳后肿胀","level":"medium","action":"clinic"},{"condition":"耳痛伴发热或流脓","level":"medium","action":"clinic"},{"condition":"耳痛伴耳后红肿压痛、头痛高热、神志改变","level":"critical","action":"emergency"}]}
{"symptom":"牙痛","population":"all","triage_rules":[{"condition":"局部牙痛，能进食，无面部肿胀发热","level":"medium","action":"clinic"},{"condition":"面部肿胀或张口受限","level":"high","action":"emergency"},{"condition":"牙源感染伴呼吸困难/吞咽困难/颈部快速肿胀/高热寒战","level":"critical","action":"emergency"}]}
{"symptom":"外伤/割伤","population":"all","triage_rules":[{"condition":"小伤口可止血、无明显污染、活动正常","level":"medium","action":"clinic"},{"condition":"伤口较深需要缝合或污染明显/动物咬伤","level":"high","action":"emergency"},{"condition":"出血止不住/喷射样出血 或 肢体麻木苍白/疑大血管神经损伤","level":"critical","action":"emergency"}]}
{"symptom":"头部外伤","population":"all","triage_rules":[{"condition":"轻微撞击，无呕吐，无意识改变","level":"medium","action":"clinic"},{"condition":"头痛加重或一次以上呕吐","level":"high","action":"emergency"},{"condition":"嗜睡叫不醒/意识混乱/抽搐/一侧无力/抗凝药使用者受伤","level":"critical","action":"emergency"}]}
{"symptom":"骨折疑似/肢体剧痛","population":"all","triage_rules":[{"condition":"轻度扭伤，能负重/活动，肿胀不重","level":"medium","action":"clinic"},{"condition":"不能负重或明显肿胀瘀青","level":"high","action":"emergency"},{"condition":"畸形/开放性伤口/肢端发凉麻木或感觉运动障碍","level":"critical","action":"emergency"}]}
{"symptom":"烧伤/烫伤","population":"all","triage_rules":[{"condition":"小面积浅表烫伤（红痛无大水疱）","level":"medium","action":"clinic"},{"condition":"起大水疱或面积较大/位于手脚关节","level":"high","action":"emergency"},{"condition":"面部/会阴/大面积烧伤 或 吸入性损伤（咳黑痰、声音嘶哑、呼吸困难）或 化学灼伤","level":"critical","action":"emergency"}]}
{"symptom":"误服/中毒","population":"all","triage_rules":[{"condition":"误服量极小且明确无毒（需专业确认）","level":"high","action":"emergency"},{"condition":"误服不明药物/化学品/农药 或 出现呕吐嗜睡","level":"critical","action":"emergency"},{"condition":"意识不清/抽搐/呼吸困难/低血压","level":"critical","action":"emergency"}]}
{"symptom":"一氧化碳中毒疑似","population":"all","triage_rules":[{"condition":"轻度头痛恶心且已脱离现场","level":"high","action":"emergency"},{"condition":"同屋多人同时头痛恶心、使用燃气热水器/炭火取暖史","level":"critical","action":"emergency"},{"condition":"意识模糊/昏迷/抽搐","level":"critical","action":"emergency"}]}
{"symptom":"高血压相关不适","population":"adult","triage_rules":[{"condition":"无症状，仅测量偏高（需重复正确测量）","level":"medium","action":"clinic"},{"condition":"头痛胸闷心悸伴血压明显升高","level":"high","action":"emergency"},{"condition":"血压升高伴胸痛/呼吸困难/神经功能缺损（口齿不清、偏瘫）","level":"critical","action":"emergency"}]}
{"symptom":"低血糖","population":"all","triage_rules":[{"condition":"轻度出汗心慌饥饿、能口服糖且缓解","level":"high","action":"emergency"},{"condition":"反复低血糖或糖尿病用药相关无法稳定","level":"high","action":"emergency"},{"condition":"意识不清/抽搐/无法进食","level":"critical","action":"emergency"}]}
{"symptom":"胸闷","population":"adult","triage_rules":[{"condition":"轻度胸闷，可能与焦虑或上呼吸道感染相关，无胸痛无气促","level":"medium","action":"clinic"},{"condition":"胸闷伴活动耐量下降或夜间憋醒","level":"high","action":"emergency"},{"condition":"胸闷伴压榨样胸痛/呼吸困难/出汗/晕厥","level":"critical","action":"emergency"}]}
{"symptom":"下肢肿胀","population":"adult","triage_rules":[{"condition":"双下肢轻度对称水肿，无气促","level":"medium","action":"clinic"},{"condition":"单侧下肢肿胀疼痛发热（疑血栓）","level":"high","action":"emergency"},{"condition":"下肢肿胀伴呼吸困难/胸痛/咳血（疑肺栓塞）","level":"critical","action":"emergency"}]}
{"symptom":"咳血","population":"adult","triage_rules":[{"condition":"少量血丝，生命体征稳定","level":"high","action":"emergency"},{"condition":"反复咳血或伴发热消瘦夜汗","level":"high","action":"emergency"},{"condition":"大量咳血/呼吸困难/晕厥","level":"critical","action":"emergency"}]}
{"symptom":"腹胀","population":"adult","triage_rules":[{"condition":"轻度腹胀与饮食相关，能排气排便","level":"medium","action":"clinic"},{"condition":"腹胀伴便秘>3天或间断绞痛","level":"high","action":"emergency"},{"condition":"腹胀伴持续剧痛/呕吐不止/停止排气排便（疑肠梗阻）","level":"critical","action":"emergency"}]}
{"symptom":"便秘","population":"adult","triage_rules":[{"condition":"便秘<1周，无腹痛呕吐，无便血","level":"medium","action":"clinic"},{"condition":"便秘伴腹痛腹胀明显","level":"high","action":"emergency"},{"condition":"停止排气排便+呕吐/腹部剧痛或黑便便血","level":"critical","action":"emergency"}]}
{"symptom":"阴道异常出血","population":"女性","triage_rules":[{"condition":"少量出血，无头晕，非妊娠且无严重腹痛","level":"high","action":"emergency"},{"condition":"月经量明显增多或出血持续>7天","level":"high","action":"emergency"},{"condition":"妊娠期出血 或 出血伴剧烈腹痛/晕厥/肩痛（疑宫外孕）","level":"critical","action":"emergency"}]}
{"symptom":"妊娠腹痛","population":"孕妇","triage_rules":[{"condition":"轻度牵拉样疼痛，无出血，无发热","level":"high","action":"emergency"},{"condition":"持续腹痛或伴尿痛/发热","level":"high","action":"emergency"},{"condition":"腹痛伴阴道出血/头晕晕厥/胎动明显减少","level":"critical","action":"emergency"}]}
{"symptom":"产后出血/不适","population":"产妇","triage_rules":[{"condition":"少量恶露逐渐减少，无发热无臭味","level":"high","action":"emergency"},{"condition":"恶露增多或伴发热腹痛","level":"critical","action":"emergency"},{"condition":"大量出血（浸透卫生巾很快）或头晕心慌/晕厥","level":"critical","action":"emergency"}]}
{"symptom":"乳房疼痛/肿块","population":"女性","triage_rules":[{"condition":"随月经周期波动的胀痛，无红肿发热","level":"medium","action":"clinic"},{"condition":"局部红肿热痛或哺乳期发热（疑乳腺炎）","level":"high","action":"emergency"},{"condition":"乳房红肿伴高热寒战或全身状况差","level":"critical","action":"emergency"}]}
{"symptom":"睾丸疼痛","population":"男性","triage_rules":[{"condition":"轻度隐痛，无肿胀发热","level":"high","action":"emergency"},{"condition":"疼痛伴阴囊肿胀或发热","level":"high","action":"emergency"},{"condition":"突发剧烈睾丸痛、抬高不缓解、恶心呕吐（疑扭转）","level":"critical","action":"emergency"}]}
{"symptom":"阴囊肿胀","population":"男性","triage_rules":[{"condition":"缓慢出现、无明显痛","level":"medium","action":"clinic"},{"condition":"肿胀疼痛或伴发热","level":"high","action":"emergency"},{"condition":"突发剧烈疼痛或伴呕吐/发紫/触痛明显","level":"critical","action":"emergency"}]}
{"symptom":"关节痛","population":"adult","triage_rules":[{"condition":"轻中度关节痛，无红肿热，无外伤史","level":"medium","action":"clinic"},{"condition":"关节红肿热痛、活动明显受限或发热","level":"high","action":"emergency"},{"condition":"关节痛伴高热寒战/皮疹紫癜/严重全身不适（疑感染性关节炎等）","level":"critical","action":"emergency"}]}
{"symptom":"皮肤/软组织红肿疼痛","population":"all","triage_rules":[{"condition":"局部小范围红肿痛，无发热","level":"medium","action":"clinic"},{"condition":"红肿范围扩大或伴发热","level":"high","action":"emergency"},{"condition":"进展极快、剧痛不成比例、皮肤发紫起泡、意识差（疑坏死性筋膜炎）","level":"critical","action":"emergency"}]}
{"symptom":"乏力","population":"adult","triage_rules":[{"condition":"短期乏力与熬夜压力相关，能正常进食活动","level":"medium","action":"clinic"},{"condition":"乏力持续>2周或伴体重下降/夜汗/心悸气短","level":"high","action":"emergency"},{"condition":"乏力伴胸痛/呼吸困难/晕厥/黑便便血/意识改变","level":"critical","action":"emergency"}]}
{"symptom":"体重下降","population":"adult","triage_rules":[{"condition":"<5%体重/3个月且有饮食运动解释","level":"medium","action":"clinic"},{"condition":"无意体重下降≥5%/3个月 或 伴食欲差贫血症状","level":"high","action":"emergency"},{"condition":"体重下降伴咳血/黑便/持续发热夜汗或明显虚弱脱水","level":"critical","action":"emergency"}]}
{"symptom":"失眠/焦虑相关不适","population":"adult","triage_rules":[{"condition":"轻中度失眠焦虑，无自伤风险，无胸痛气促","level":"medium","action":"clinic"},{"condition":"伴明显躯体症状反复（心悸胸闷）影响生活","level":"medium","action":"clinic"},{"condition":"出现自杀意念/自伤行为 或 幻觉妄想/极度激越","level":"critical","action":"emergency"}]}
{"symptom":"背部/胸背撕裂样痛","population":"adult","triage_rules":[{"condition":"与肌肉拉伤相关、按压痛明显","level":"high","action":"emergency"},{"condition":"突发撕裂样背痛或胸背痛","level":"critical","action":"emergency"},{"condition":"伴晕厥/神经症状/血压异常（疑主动脉夹层等）","level":"critical","action":"emergency"}]}
{"symptom":"肢体麻木/无力","population":"adult","triage_rules":[{"condition":"短暂麻木与姿势压迫相关，改变体位可缓解","level":"high","action":"emergency"},{"condition":"麻木无力反复发作或逐渐加重","level":"high","action":"emergency"},{"condition":"突发单侧无力/口角歪斜/言语含糊/视力异常（疑卒中）","level":"critical","action":"emergency"}]}
{"symptom":"皮肤苍白/头晕","population":"all","triage_rules":[{"condition":"轻度头晕，进食不足或体位性明显","level":"high","action":"emergency"},{"condition":"伴心悸气短或经量大/近期失血可能","level":"high","action":"emergency"},{"condition":"伴黑便/便血/呕血/晕厥或休克表现（冷汗四肢冰冷）","level":"critical","action":"emergency"}]}
{"symptom":"胸口烧灼/反酸","population":"adult","triage_rules":[{"condition":"餐后反酸烧心，可通过生活方式调整缓解","level":"medium","action":"clinic"},{"condition":"症状频繁每周≥2次或夜间反流影响睡眠","level":"medium","action":"clinic"},{"condition":"伴吞咽困难/呕血黑便/体重下降或胸痛不能排除心脏问题","level":"critical","action":"emergency"}]}
{"symptom":"吞咽困难","population":"adult","triage_rules":[{"condition":"轻度吞咽不适，间歇出现","level":"high","action":"emergency"},{"condition":"进行性加重或伴体重下降","level":"high","action":"emergency"},{"condition":"无法吞咽口水/流口水 或 伴呼吸困难/喉头肿胀","level":"critical","action":"emergency"}]}
{"symptom":"四肢水肿","population":"all","triage_rules":[{"condition":"轻度水肿，无气促胸痛","level":"medium","action":"clinic"},{"condition":"水肿伴尿量减少或泡沫尿","level":"high","action":"emergency"},{"condition":"水肿伴呼吸困难/胸痛/意识差或无尿","level":"critical","action":"emergency"}]}
{"symptom":"黄疸/皮肤眼睛发黄","population":"all","triage_rules":[{"condition":"轻度黄疸，无腹痛发热","level":"high","action":"emergency"},{"condition":"黄疸伴上腹痛或瘙痒明显","level":"high","action":"emergency"},{"condition":"黄疸伴发热寒战/意识改变/低血压（疑胆管炎等）","level":"critical","action":"emergency"}]}
{"symptom":"咽喉异物感/疑异物卡住","population":"all","triage_rules":[{"condition":"能正常呼吸说话，仅轻微异物感","level":"high","action":"emergency"},{"condition":"吞咽疼痛明显或怀疑鱼刺/尖锐异物","level":"high","action":"emergency"},{"condition":"呼吸困难/流口水/无法吞咽或疑气道异物突发呛咳","level":"critical","action":"emergency"}]}